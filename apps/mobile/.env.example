# Set these via Expo's env config (app.config.js + EAS secrets for real builds).
# EXPO_PUBLIC_* vars ARE inlined into the app bundle by design (same idea as
# Next.js's NEXT_PUBLIC_*) — that's fine here because a Firebase web config is
# not itself a secret; real protection is Firestore rules + App Check, not secrecy
# of these values. Never put RAZORPAY_KEY_SECRET, STRIPE_SECRET_KEY, or
# ANTHROPIC_API_KEY in EXPO_PUBLIC_* — those stay server-side in functions/.env only.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
