rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "moderator"];
    }
    // Fields only a trusted Cloud Function (webhook handlers) may ever write.
    // Enforced by diffing changed keys against this denylist on every users/{uid} write.
    function touchesProtectedBillingFields() {
      let protectedKeys = [
        'subscriptionStatus', 'subscriptionExpiresAt',
        'subscriptionPlatform', 'subscriptionRenewalId', 'role'
      ];
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedKeys);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
        request.resource.data.subscriptionStatus == 'free' &&
        request.resource.data.role == 'user';
      // A user may update their own profile fields, but NEVER self-grant premium/role.
      // This is the negative test required by Section 15.1 #3.
      allow update: if isOwner(userId) && !touchesProtectedBillingFields() || isAdmin();
      allow delete: if false;

      match /mindMaps/{mapId} {
        allow read: if isOwner(userId) || (resource.data.isPublic == true);
        allow write: if isOwner(userId);
      }
      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }
      match /quizzes/{quizId} {
        allow read, write: if isOwner(userId);
      }
      match /quizAttempts/{attemptId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false; // attempts are immutable once recorded
      }
      match /flashcardDecks/{deckId} {
        allow read: if isOwner(userId) || (resource.data.isPublic == true);
        allow write: if isOwner(userId);

        match /cards/{cardId} {
          allow read, write: if isOwner(userId);
        }
      }
      match /codingProgress/{problemId} {
        allow read, write: if isOwner(userId);
      }
      match /roadmaps/{roadmapId} {
        allow read, write: if isOwner(userId);
      }
      match /activityHistory/{itemId} {
        allow read, write: if isOwner(userId);
      }
      match /tutorSessions/{sessionId} {
        allow read, write: if isOwner(userId);

        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // Curated, admin-managed content — world-readable, admin/moderator-writable only.
    match /publicContent/{collection}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminMeta/appConfig {
      allow read: if true; // freeLimits/featureFlags must be readable client-side
      allow write: if isAdmin();
    }
    match /adminMeta/moderationQueue/items/{itemId} {
      allow read, write: if isAdmin();
    }

    match /analyticsAggregates/{date} {
      allow read: if isAdmin();
      allow write: if false; // written only by scheduled Cloud Function via Admin SDK
    }

    // Payment audit trail — written only by webhook Cloud Functions (Admin SDK bypasses
    // these rules entirely), readable by the owning user and admins for transparency/support.
    match /users/{userId}/subscriptionEvents/{eventId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // Deny-all default for anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
