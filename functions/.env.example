# Every value below is set with `firebase functions:secrets:set <NAME>` in real deployments.
# NONE of these are ever sent to the browser, bundled into client JS, or visible via
# "Inspect" / dev tools — they only exist inside Cloud Functions running on Google's
# servers. The client only ever receives IDs/tokens these functions choose to return
# (e.g. an order_id, a public key_id) — never the secret keys themselves.

ANTHROPIC_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
